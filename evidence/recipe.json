{
  "title": "HL balance live-update parity across account abstraction modes",
  "description": "Cycles the account through Standard and Unified abstraction modes, validating fold invariant + REST parity + UI wiring + limit-order hold/release in each. Captures a screenshot after every key validation point so a cold reviewer can eyeball the evidence without re-running. Setup/teardown cancel any leftover open orders so mode flips don't fail on 'cannot disable unified with open orders'. Known asymmetry: teardown always restores to Unified (does not preserve the exact pre-recipe mode) — safe for the shared Trading fixture which is Unified by convention. Runs on both testnet and mainnet.",
  "validate": {
    "workflow": {
      "pre_conditions": [
        "wallet.unlocked",
        "perps.feature_enabled",
        "perps.ready_to_trade"
      ],
      "setup": [
        {
          "id": "reset-payment-token",
          "action": "eval_async",
          "expression": "(function(){try{var c=Engine.context.PerpsController;c.clearPendingTradeConfiguration&&c.clearPendingTradeConfiguration('BTC');c.resetSelectedPaymentToken&&c.resetSelectedPaymentToken();return Promise.resolve(JSON.stringify({ok:true}))}catch(e){return Promise.resolve(JSON.stringify({ok:false,error:String(e)}))}})()",
          "assert": { "operator": "eq", "field": "ok", "value": true }
        },
        {
          "id": "cancel-leftover-orders",
          "action": "eval_async",
          "expression": "(function(){try{return Engine.context.PerpsController.cancelOrders({cancelAll:true}).then(function(r){return JSON.stringify({ok:true,cleared:(r&&r.successCount)||0})}).catch(function(e){return JSON.stringify({ok:true,cleared:0,note:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({ok:true,cleared:0,error:String(e)}))}})()",
          "assert": { "operator": "eq", "field": "ok", "value": true },
          "timeout_ms": 30000
        },
        {
          "id": "close-leftover-positions",
          "action": "eval_async",
          "expression": "(function(){try{return Engine.context.PerpsController.closePositions({closeAll:true}).then(function(r){return JSON.stringify({ok:true,closed:(r&&r.successCount)||0})}).catch(function(e){return JSON.stringify({ok:true,closed:0,note:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({ok:true,closed:0,error:String(e)}))}})()",
          "assert": { "operator": "eq", "field": "ok", "value": true },
          "timeout_ms": 60000
        },
        {
          "id": "capture-initial-state",
          "action": "eval_async",
          "expression": "(function(){try{var ctrl=Engine.context.PerpsController;var accs=Engine.context.AccountsController.state.internalAccounts;var user=accs.accounts[accs.selectedAccount].address;return ctrl.getAccountState({standalone:true,userAddress:user}).then(function(s){return JSON.stringify({ok:true,user:user,startingTotal:s.totalBalance,startingAvailable:s.availableBalance,startingTradeable:s.availableToTradeBalance})}).catch(function(e){return JSON.stringify({ok:false,error:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({ok:false,error:String(e)}))}})()",
          "assert": { "operator": "eq", "field": "ok", "value": true },
          "save_as": "initial",
          "timeout_ms": 15000
        }
      ],
      "entry": "set-standard",
      "nodes": {
        "set-standard": {
          "action": "call",
          "ref": "perps/hl-provision-fixture",
          "params": { "abstraction": "disabled", "transferDirection": "none" },
          "next": "validate-standard"
        },
        "validate-standard": {
          "action": "call",
          "ref": "perps/hl-balance-validation",
          "params": { "expectedMode": "standard", "phaseLabel": "standard" },
          "next": "parity-standard"
        },
        "parity-standard": {
          "action": "eval_async",
          "expression": "(function(){try{var ctrl=Engine.context.PerpsController;var stream=(ctrl.state&&ctrl.state.accountState)||{};var accs=Engine.context.AccountsController.state.internalAccounts;var user=accs.accounts[accs.selectedAccount].address;return ctrl.getAccountState({standalone:true,userAddress:user}).then(function(standalone){function n(v){return parseFloat(v||'0')}var dAvail=Math.abs(n(stream.availableBalance)-n(standalone.availableBalance));var dTrade=Math.abs(n(stream.availableToTradeBalance||stream.availableBalance)-n(standalone.availableToTradeBalance||standalone.availableBalance));var dTotal=Math.abs(n(stream.totalBalance)-n(standalone.totalBalance));var tol=0.1;return JSON.stringify({phase:'standard',streamAvail:stream.availableBalance,streamTrade:stream.availableToTradeBalance,streamTotal:stream.totalBalance,restAvail:standalone.availableBalance,restTrade:standalone.availableToTradeBalance,restTotal:standalone.totalBalance,availParity:dAvail<=tol,tradeParity:dTrade<=tol,totalParity:dTotal<=tol})}).catch(function(e){return JSON.stringify({phase:'standard',availParity:false,tradeParity:false,totalParity:false,error:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({phase:'standard',availParity:false,tradeParity:false,totalParity:false,error:String(e)}))}})()",
          "assert": {
            "all": [
              { "operator": "eq", "field": "availParity", "value": true },
              { "operator": "eq", "field": "tradeParity", "value": true },
              { "operator": "eq", "field": "totalParity", "value": true }
            ]
          },
          "timeout_ms": 20000,
          "next": "screenshot-standard-summary"
        },
        "screenshot-standard-summary": {
          "action": "screenshot",
          "filename": "phase-standard-summary.png",
          "next": "set-unified"
        },
        "set-unified": {
          "action": "call",
          "ref": "perps/hl-provision-fixture",
          "params": {
            "abstraction": "unifiedAccount",
            "transferDirection": "none"
          },
          "next": "validate-unified"
        },
        "validate-unified": {
          "action": "call",
          "ref": "perps/hl-balance-validation",
          "params": { "expectedMode": "unified", "phaseLabel": "unified" },
          "next": "parity-unified"
        },
        "parity-unified": {
          "action": "eval_async",
          "expression": "(function(){try{var ctrl=Engine.context.PerpsController;var stream=(ctrl.state&&ctrl.state.accountState)||{};var accs=Engine.context.AccountsController.state.internalAccounts;var user=accs.accounts[accs.selectedAccount].address;return ctrl.getAccountState({standalone:true,userAddress:user}).then(function(standalone){function n(v){return parseFloat(v||'0')}var dAvail=Math.abs(n(stream.availableBalance)-n(standalone.availableBalance));var dTrade=Math.abs(n(stream.availableToTradeBalance||stream.availableBalance)-n(standalone.availableToTradeBalance||standalone.availableBalance));var dTotal=Math.abs(n(stream.totalBalance)-n(standalone.totalBalance));var tol=0.1;return JSON.stringify({phase:'unified',streamAvail:stream.availableBalance,streamTrade:stream.availableToTradeBalance,streamTotal:stream.totalBalance,restAvail:standalone.availableBalance,restTrade:standalone.availableToTradeBalance,restTotal:standalone.totalBalance,availParity:dAvail<=tol,tradeParity:dTrade<=tol,totalParity:dTotal<=tol})}).catch(function(e){return JSON.stringify({phase:'unified',availParity:false,tradeParity:false,totalParity:false,error:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({phase:'unified',availParity:false,tradeParity:false,totalParity:false,error:String(e)}))}})()",
          "assert": {
            "all": [
              { "operator": "eq", "field": "availParity", "value": true },
              { "operator": "eq", "field": "tradeParity", "value": true },
              { "operator": "eq", "field": "totalParity", "value": true }
            ]
          },
          "timeout_ms": 20000,
          "next": "order-form-wiring-unified"
        },
        "order-form-wiring-unified": {
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "BTC",
              "name": "BTC",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          },
          "next": "wait-long"
        },
        "wait-long": {
          "action": "wait_for",
          "test_id": "perps-market-details-long-button",
          "timeout_ms": 15000,
          "next": "press-long"
        },
        "press-long": {
          "action": "press",
          "test_id": "perps-market-details-long-button",
          "next": "wait-place-order"
        },
        "wait-place-order": {
          "action": "wait_for",
          "test_id": "perps-order-view-place-order-button",
          "timeout_ms": 15000,
          "next": "check-order-form"
        },
        "check-order-form": {
          "action": "eval_sync",
          "expression": "(function(){try{var a=globalThis.__AGENTIC__;var paySymbol=(a&&a.getTextByTestId('pay-with-symbol'))||'';var placeOrderMounted=!!(a&&a.findFiberByTestId&&a.findFiberByTestId('perps-order-view-place-order-button'));var s=(Engine.context.PerpsController.state&&Engine.context.PerpsController.state.accountState)||{};var trade=parseFloat(s.availableToTradeBalance||s.availableBalance||'0');var paysPerps=paySymbol.toLowerCase().indexOf('perps')>=0;var expectTradeable=trade>0.5;var defaultsToPerps=expectTradeable?paysPerps:true;return JSON.stringify({paySymbol:paySymbol,availableToTradeBalance:trade,placeOrderMounted:placeOrderMounted,paysWithPerpsBalance:paysPerps,defaultsToPerps:defaultsToPerps})}catch(e){return JSON.stringify({error:String(e)})}})()",
          "assert": {
            "all": [
              { "operator": "eq", "field": "placeOrderMounted", "value": true },
              { "operator": "eq", "field": "defaultsToPerps", "value": true }
            ]
          },
          "next": "screenshot-order-form"
        },
        "screenshot-order-form": {
          "action": "screenshot",
          "filename": "phase-unified-order-form.png",
          "next": "limit-cycle-nav-wallet"
        },
        "limit-cycle-nav-wallet": {
          "action": "navigate",
          "target": "Wallet",
          "next": "limit-cycle-cleanup-existing"
        },
        "limit-cycle-cleanup-existing": {
          "action": "eval_async",
          "expression": "(function(){try{return Engine.context.PerpsController.cancelOrders({cancelAll:true}).then(function(r){return JSON.stringify({ok:true,cleared:(r&&r.successCount)||0})}).catch(function(e){return JSON.stringify({ok:true,cleared:0,note:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({ok:true,cleared:0,error:String(e)}))}})()",
          "assert": { "operator": "eq", "field": "ok", "value": true },
          "timeout_ms": 30000,
          "next": "limit-cycle-baseline"
        },
        "limit-cycle-baseline": {
          "action": "eval_sync",
          "expression": "(function(){var s=(Engine.context.PerpsController.state&&Engine.context.PerpsController.state.accountState)||{};var trade=parseFloat(s.availableToTradeBalance||s.availableBalance||'0');var total=parseFloat(s.totalBalance||'0');return JSON.stringify({baselineTradeable:trade,totalBalance:total,convergent:Math.abs(trade-total)<=0.2})})()",
          "assert": {
            "all": [
              { "operator": "gt", "field": "baselineTradeable", "value": 1 },
              { "operator": "eq", "field": "convergent", "value": true }
            ]
          },
          "next": "screenshot-limit-baseline"
        },
        "screenshot-limit-baseline": {
          "action": "screenshot",
          "filename": "limit-cycle-0-baseline.png",
          "next": "limit-cycle-place"
        },
        "limit-cycle-place": {
          "action": "eval_async",
          "expression": "(function(){try{return Engine.context.PerpsController.getMarketDataWithPrices().then(function(markets){var m=null;for(var i=0;i<markets.length;i++){if(markets[i].symbol==='BTC'){m=markets[i];break}}var raw=m?String(m.price):'70000';var mid=parseFloat(raw.replace(/[$,]/g,''));var farPrice=Math.floor(mid*0.5).toString();return Engine.context.PerpsController.placeOrder({symbol:'BTC',isBuy:true,orderType:'limit',price:farPrice,size:'0.0002',leverage:2,usdAmount:'11',maxSlippageBps:500}).then(function(r){return JSON.stringify({ok:!!(r&&r.success),farPrice:farPrice,result:r})})}).catch(function(e){return JSON.stringify({ok:false,error:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({ok:false,error:String(e)}))}})()",
          "assert": { "operator": "eq", "field": "ok", "value": true },
          "timeout_ms": 30000,
          "next": "limit-cycle-wait-hold"
        },
        "limit-cycle-wait-hold": {
          "action": "wait_for",
          "expression": "(function(){var s=(Engine.context.PerpsController.state&&Engine.context.PerpsController.state.accountState)||{};var trade=parseFloat(s.availableToTradeBalance||s.availableBalance||'0');var total=parseFloat(s.totalBalance||'0');return JSON.stringify({tradeable:trade,totalBalance:total,holdApplied:trade<total-0.1})})()",
          "assert": { "operator": "eq", "field": "holdApplied", "value": true },
          "timeout_ms": 10000,
          "next": "screenshot-limit-hold-applied"
        },
        "screenshot-limit-hold-applied": {
          "action": "screenshot",
          "filename": "limit-cycle-1-hold-applied.png",
          "next": "limit-cycle-cancel-all"
        },
        "limit-cycle-cancel-all": {
          "action": "eval_async",
          "expression": "(function(){try{return Engine.context.PerpsController.cancelOrders({cancelAll:true}).then(function(r){return JSON.stringify({ok:!!(r&&r.success),successCount:(r&&r.successCount)||0})}).catch(function(e){return JSON.stringify({ok:false,error:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({ok:false,error:String(e)}))}})()",
          "assert": {
            "all": [
              { "operator": "eq", "field": "ok", "value": true },
              { "operator": "gt", "field": "successCount", "value": 0 }
            ]
          },
          "timeout_ms": 30000,
          "next": "limit-cycle-wait-release"
        },
        "limit-cycle-wait-release": {
          "action": "wait_for",
          "expression": "(function(){var s=(Engine.context.PerpsController.state&&Engine.context.PerpsController.state.accountState)||{};var trade=parseFloat(s.availableToTradeBalance||s.availableBalance||'0');var total=parseFloat(s.totalBalance||'0');var released=Math.abs(trade-total)<=0.2;return JSON.stringify({tradeable:trade,totalBalance:total,holdReleased:released})})()",
          "assert": {
            "operator": "eq",
            "field": "holdReleased",
            "value": true
          },
          "timeout_ms": 15000,
          "next": "screenshot-limit-hold-released"
        },
        "screenshot-limit-hold-released": {
          "action": "screenshot",
          "filename": "limit-cycle-2-hold-released.png",
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass"
        }
      },
      "teardown": [
        {
          "id": "teardown-cancel-orders",
          "action": "eval_async",
          "expression": "(function(){try{return Engine.context.PerpsController.cancelOrders({cancelAll:true}).then(function(r){return JSON.stringify({ok:true,cleared:(r&&r.successCount)||0})}).catch(function(e){return JSON.stringify({ok:false,cleared:0,error:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({ok:false,cleared:0,error:String(e)}))}})()",
          "assert": { "operator": "eq", "field": "ok", "value": true },
          "timeout_ms": 30000
        },
        {
          "id": "teardown-close-positions",
          "action": "eval_async",
          "expression": "(function(){try{return Engine.context.PerpsController.closePositions({closeAll:true}).then(function(r){return JSON.stringify({ok:true,closed:(r&&r.successCount)||0})}).catch(function(e){return JSON.stringify({ok:false,closed:0,error:String(e&&e.message||e)})})}catch(e){return Promise.resolve(JSON.stringify({ok:false,closed:0,error:String(e)}))}})()",
          "assert": { "operator": "eq", "field": "ok", "value": true },
          "timeout_ms": 60000
        },
        {
          "id": "restore-unified",
          "action": "call",
          "ref": "perps/hl-provision-fixture",
          "params": {
            "abstraction": "unifiedAccount",
            "transferDirection": "none"
          }
        }
      ]
    }
  }
}

{
  "title": "TAT-3016 validation: availableToTradeBalance populated and bounded correctly",
  "description": "Asserts the hotfix contract on fixtures that are pre-provisioned. Scenario 1 (dev1 / Standard mode): availableToTradeBalance === availableBalance with no spot contribution. Scenario 2 (Trading / Unified mode): availableToTradeBalance >= availableBalance (spot USDC/USDH folded in). Both scenarios capture a PerpsMarketDetails screenshot showing the correct Long/Short CTA state instead of the Add Funds CTA. Scenarios for dev2 (spot-only) and dev3 (empty) require manual HL web UI setup; see evidence/QA.md §Manual setup and drive those scenarios by hand with xcrun simctl io recordVideo. Recipe FAILS if the hotfix regresses either guaranteed-fixture invariant.",
  "initial_conditions": {
    "testnet": false
  },
  "validate": {
    "workflow": {
      "pre_conditions": [],
      "entry": "detect-route",
      "nodes": {
        "detect-route": {
          "action": "eval_sync",
          "expression": "(function(){try{var r=globalThis.__AGENTIC__&&globalThis.__AGENTIC__.getRoute();return JSON.stringify({route:r?r.name:'unknown'})}catch(e){return JSON.stringify({route:'unknown'})}})()",
          "assert": { "operator": "not_null", "field": "route" },
          "next": "route-switch"
        },
        "route-switch": {
          "action": "switch",
          "cases": [
            {
              "label": "needs-login",
              "when": {
                "operator": "eq",
                "field": "nodes.detect-route.result.route",
                "value": "Login"
              },
              "next": "enter-password"
            }
          ],
          "default": "assert-mainnet"
        },
        "enter-password": {
          "action": "set_input",
          "test_id": "login-password-input",
          "value": "qwerasdf",
          "next": "press-login"
        },
        "press-login": {
          "action": "press",
          "test_id": "log-in-button",
          "next": "wait-unlocked"
        },
        "wait-unlocked": {
          "action": "wait_for",
          "expression": "(function(){try{var r=globalThis.__AGENTIC__&&globalThis.__AGENTIC__.getRoute();var name=r?r.name:'';return JSON.stringify({unlocked:name!==''&&name!=='Login'&&name!=='LoginView'&&name!=='Onboarding'})}catch(e){return JSON.stringify({unlocked:false})}})()",
          "assert": { "operator": "eq", "field": "unlocked", "value": true },
          "timeout_ms": 20000,
          "next": "assert-mainnet"
        },
        "assert-mainnet": {
          "action": "eval_sync",
          "expression": "JSON.stringify({isTestnet:Engine.context.PerpsController.state&&Engine.context.PerpsController.state.isTestnet===true})",
          "assert": { "operator": "eq", "field": "isTestnet", "value": false },
          "next": "dev1-select"
        },

        "dev1-select": {
          "action": "select_account",
          "address": "0x8Dc623E964475D4d669da601Fd15ea9125469003",
          "next": "dev1-wait-switch"
        },
        "dev1-wait-switch": {
          "action": "wait",
          "ms": 2000,
          "next": "dev1-wait-provider"
        },
        "dev1-wait-provider": {
          "action": "wait_for",
          "expression": "(function(){try{var ctrl=Engine.context.PerpsController;var ready=!!(ctrl&&ctrl.state&&ctrl.state.activeProvider);return JSON.stringify({ready:ready})}catch(e){return JSON.stringify({ready:false})}})()",
          "assert": { "operator": "eq", "field": "ready", "value": true },
          "timeout_ms": 20000,
          "next": "dev1-pre-trade"
        },
        "dev1-pre-trade": {
          "action": "eval_ref",
          "ref": "perps/pre-trade",
          "assert": {
            "all": [
              { "operator": "not_null", "field": "accountState" },
              {
                "operator": "not_null",
                "field": "accountState.availableToTradeBalance"
              }
            ]
          },
          "save_as": "dev1_state",
          "timeout_ms": 20000,
          "next": "dev1-assert-balances"
        },
        "dev1-assert-balances": {
          "action": "eval_sync",
          "expression": "(function(){var s=vars.dev1_state&&vars.dev1_state.accountState?vars.dev1_state.accountState:{};var avail=parseFloat(s.availableBalance||'0');var trade=parseFloat(s.availableToTradeBalance||s.availableBalance||'0');return JSON.stringify({availableBalance:avail,availableToTradeBalance:trade,standardModeInvariant:trade===avail,hasBuyingPower:trade>11})})()",
          "assert": {
            "all": [
              {
                "operator": "eq",
                "field": "standardModeInvariant",
                "value": true
              },
              { "operator": "eq", "field": "hasBuyingPower", "value": true }
            ]
          },
          "next": "dev1-nav-market"
        },
        "dev1-nav-market": {
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "BTC",
              "name": "BTC",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          },
          "next": "dev1-wait-market"
        },
        "dev1-wait-market": {
          "action": "wait_for",
          "expression": "(function(){try{var r=globalThis.__AGENTIC__&&globalThis.__AGENTIC__.getRoute();return JSON.stringify({route:r?r.name:'unknown'})}catch(e){return JSON.stringify({route:'unknown'})}})()",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "PerpsMarketDetails"
          },
          "timeout_ms": 15000,
          "next": "dev1-settle"
        },
        "dev1-settle": {
          "action": "wait",
          "ms": 2000,
          "next": "dev1-screenshot"
        },
        "dev1-screenshot": {
          "action": "screenshot",
          "filename": "tat3016-dev1-standard-mode.png",
          "next": "dev1-assert-long-cta"
        },
        "dev1-assert-long-cta": {
          "action": "eval_sync",
          "expression": "(function(){try{var found={longButtonVisible:false,addFundsVisible:false};function walk(f){if(!f)return;var tid=f.memoizedProps&&f.memoizedProps.testID;if(tid==='perps-market-details-long-button')found.longButtonVisible=true;if(tid==='perps-market-details-add-funds-button')found.addFundsVisible=true;walk(f.child);walk(f.sibling)}var hook=globalThis.__REACT_DEVTOOLS_GLOBAL_HOOK__;if(hook&&hook.renderers){var ids=Array.from(hook.renderers.keys?hook.renderers.keys():[]);ids.forEach(function(id){var roots=hook.getFiberRoots(id);roots.forEach(function(r){walk(r.current)})})}return JSON.stringify(found)}catch(e){return JSON.stringify({error:String(e)})}})()",
          "assert": {
            "all": [
              { "operator": "eq", "field": "longButtonVisible", "value": true },
              { "operator": "eq", "field": "addFundsVisible", "value": false }
            ]
          },
          "next": "trading-select"
        },

        "trading-select": {
          "action": "select_account",
          "address": "0x316BDE155acd07609872a56Bc32CcfB0B13201fA",
          "next": "trading-wait-switch"
        },
        "trading-wait-switch": {
          "action": "wait",
          "ms": 2000,
          "next": "trading-wait-provider"
        },
        "trading-wait-provider": {
          "action": "wait_for",
          "expression": "(function(){try{var ctrl=Engine.context.PerpsController;var ready=!!(ctrl&&ctrl.state&&ctrl.state.activeProvider);return JSON.stringify({ready:ready})}catch(e){return JSON.stringify({ready:false})}})()",
          "assert": { "operator": "eq", "field": "ready", "value": true },
          "timeout_ms": 20000,
          "next": "trading-pre-trade"
        },
        "trading-pre-trade": {
          "action": "eval_ref",
          "ref": "perps/pre-trade",
          "assert": {
            "all": [
              { "operator": "not_null", "field": "accountState" },
              {
                "operator": "not_null",
                "field": "accountState.availableToTradeBalance"
              }
            ]
          },
          "save_as": "trading_state",
          "timeout_ms": 20000,
          "next": "trading-assert-balances"
        },
        "trading-assert-balances": {
          "action": "eval_sync",
          "expression": "(function(){var s=vars.trading_state&&vars.trading_state.accountState?vars.trading_state.accountState:{};var avail=parseFloat(s.availableBalance||'0');var trade=parseFloat(s.availableToTradeBalance||s.availableBalance||'0');return JSON.stringify({availableBalance:avail,availableToTradeBalance:trade,unifiedFoldInvariant:trade>=avail,hasBuyingPower:trade>11})})()",
          "assert": {
            "all": [
              {
                "operator": "eq",
                "field": "unifiedFoldInvariant",
                "value": true
              },
              { "operator": "eq", "field": "hasBuyingPower", "value": true }
            ]
          },
          "next": "trading-nav-market"
        },
        "trading-nav-market": {
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "BTC",
              "name": "BTC",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          },
          "next": "trading-wait-market"
        },
        "trading-wait-market": {
          "action": "wait_for",
          "expression": "(function(){try{var r=globalThis.__AGENTIC__&&globalThis.__AGENTIC__.getRoute();return JSON.stringify({route:r?r.name:'unknown'})}catch(e){return JSON.stringify({route:'unknown'})}})()",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "PerpsMarketDetails"
          },
          "timeout_ms": 15000,
          "next": "trading-settle"
        },
        "trading-settle": {
          "action": "wait",
          "ms": 2000,
          "next": "trading-screenshot"
        },
        "trading-screenshot": {
          "action": "screenshot",
          "filename": "tat3016-trading-unified-mode.png",
          "next": "trading-assert-long-cta"
        },
        "trading-assert-long-cta": {
          "action": "eval_sync",
          "expression": "(function(){try{var found={longButtonVisible:false,addFundsVisible:false};function walk(f){if(!f)return;var tid=f.memoizedProps&&f.memoizedProps.testID;if(tid==='perps-market-details-long-button')found.longButtonVisible=true;if(tid==='perps-market-details-add-funds-button')found.addFundsVisible=true;walk(f.child);walk(f.sibling)}var hook=globalThis.__REACT_DEVTOOLS_GLOBAL_HOOK__;if(hook&&hook.renderers){var ids=Array.from(hook.renderers.keys?hook.renderers.keys():[]);ids.forEach(function(id){var roots=hook.getFiberRoots(id);roots.forEach(function(r){walk(r.current)})})}return JSON.stringify(found)}catch(e){return JSON.stringify({error:String(e)})}})()",
          "assert": {
            "all": [
              { "operator": "eq", "field": "longButtonVisible", "value": true },
              { "operator": "eq", "field": "addFundsVisible", "value": false }
            ]
          },
          "next": "done"
        },

        "done": {
          "action": "end",
          "status": "pass"
        }
      }
    }
  }
}

{
  "title": "Validate trade-open-market flow with SOL long $10",
  "description": "Closes any existing SOL position first to ensure long button is visible, then opens a new one.",
  "validate": {
    "runtime": {
      "steps": [
        {
          "id": "ensure-no-sol-position",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='SOL'});if(!p)return JSON.stringify({closed:true});return Engine.context.PerpsController.closePosition({symbol:'SOL'}).then(function(){return JSON.stringify({closed:true})})})",
          "assert": {
            "operator": "eq",
            "field": "closed",
            "value": true
          }
        },
        {
          "id": "wait-close",
          "action": "wait",
          "ms": 2000
        },
        {
          "id": "pre-verify-no-position",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='SOL'});return JSON.stringify({found:!!p})})",
          "assert": {
            "operator": "eq",
            "field": "found",
            "value": false
          }
        },
        {
          "id": "run-flow",
          "action": "flow_ref",
          "ref": "trade-open-market",
          "params": {
            "symbol": "SOL",
            "side": "long",
            "usdAmount": "10",
            "leverage": "2"
          }
        },
        {
          "id": "post-verify",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='SOL'});return JSON.stringify({found:!!p})})",
          "assert": {
            "operator": "eq",
            "field": "found",
            "value": true
          }
        }
      ]
    }
  }
}

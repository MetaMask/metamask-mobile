{
  "title": "Validate select-account flow",
  "validate": {
    "runtime": {
      "steps": [
        {
          "id": "run-flow",
          "action": "flow_ref",
          "ref": "select-account",
          "params": { "address": "0x8dc623e964475d4d669da601fd15ea9125469003" }
        },
        {
          "id": "post-verify-account",
          "action": "eval_sync",
          "expression": "JSON.stringify({address:Engine.context.AccountsController.state.internalAccounts.accounts[Engine.context.AccountsController.state.internalAccounts.selectedAccount].address})",
          "assert": {
            "operator": "eq",
            "field": "address",
            "value": "0x8dc623e964475d4d669da601fd15ea9125469003"
          }
        }
      ]
    }
  }
}

{
  "title": "Validate market-watchlist flow with BTC",
  "validate": {
    "runtime": {
      "steps": [
        {
          "id": "pre-snapshot-watchlist",
          "action": "eval_sync",
          "expression": "JSON.stringify({inWatchlist:(Engine.context.PerpsController.state.watchlistMarkets.mainnet||[]).indexOf('BTC')>=0||(Engine.context.PerpsController.state.watchlistMarkets.testnet||[]).indexOf('BTC')>=0})",
          "assert": {
            "operator": "not_null",
            "field": "inWatchlist"
          }
        },
        {
          "id": "run-flow",
          "action": "flow_ref",
          "ref": "market-watchlist",
          "params": { "symbol": "BTC" }
        },
        {
          "id": "post-verify-toggle",
          "action": "eval_sync",
          "expression": "JSON.stringify({inWatchlist:(Engine.context.PerpsController.state.watchlistMarkets.mainnet||[]).indexOf('BTC')>=0||(Engine.context.PerpsController.state.watchlistMarkets.testnet||[]).indexOf('BTC')>=0})",
          "assert": {
            "operator": "not_null",
            "field": "inWatchlist"
          }
        }
      ]
    }
  }
}

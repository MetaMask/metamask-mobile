{
  "title": "Validate activity-view flow with tab=trades",
  "validate": {
    "runtime": {
      "steps": [
        {
          "id": "run-flow",
          "action": "flow_ref",
          "ref": "activity-view",
          "params": { "tab": "trades" }
        },
        {
          "id": "post-verify-route",
          "action": "eval_sync",
          "expression": "JSON.stringify({route:globalThis.__AGENTIC__.getRoute().name})",
          "assert": {
            "operator": "not_null",
            "field": "route"
          }
        }
      ]
    }
  }
}

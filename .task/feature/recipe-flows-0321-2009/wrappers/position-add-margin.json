{
  "title": "Validate position-add-margin flow with BTC $5",
  "validate": {
    "runtime": {
      "steps": [
        {
          "id": "pre-snapshot-margin",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='BTC'});return JSON.stringify({margin:p?p.marginUsed:null})})",
          "assert": {
            "operator": "not_null",
            "field": "margin"
          }
        },
        {
          "id": "run-flow",
          "action": "flow_ref",
          "ref": "position-add-margin",
          "params": { "symbol": "BTC", "marginAmount": "5" }
        },
        {
          "id": "post-verify-margin",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='BTC'});return JSON.stringify({margin:p?p.marginUsed:null})})",
          "assert": {
            "operator": "not_null",
            "field": "margin"
          }
        }
      ]
    }
  }
}

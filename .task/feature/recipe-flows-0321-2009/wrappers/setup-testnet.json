{
  "title": "Validate setup-testnet flow",
  "validate": {
    "runtime": {
      "steps": [
        {
          "id": "run-flow",
          "action": "flow_ref",
          "ref": "setup-testnet"
        },
        {
          "id": "post-verify-testnet",
          "action": "eval_sync",
          "expression": "JSON.stringify({isTestnet:Engine.context.PerpsController.state.isTestnet})",
          "assert": {
            "operator": "eq",
            "field": "isTestnet",
            "value": true
          }
        }
      ]
    }
  }
}

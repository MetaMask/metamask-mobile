{
  "title": "Validate order-limit-cancel flow with ETH",
  "description": "Places an ETH limit order at a reasonable price below market, then cancels it via the flow.",
  "validate": {
    "runtime": {
      "steps": [
        {
          "id": "cleanup-existing-eth-orders",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getOpenOrders().then(function(os){var ethOrders=os.filter(function(o){return o.symbol==='ETH'&&!o.isTrigger});if(ethOrders.length===0)return JSON.stringify({cancelled:0});return Promise.all(ethOrders.map(function(o){return Engine.context.PerpsController.cancelOrder({orderId:o.orderId,symbol:'ETH'})})).then(function(results){return JSON.stringify({cancelled:results.length})})})",
          "assert": {
            "operator": "not_null",
            "field": "cancelled"
          }
        },
        {
          "id": "wait-cleanup",
          "action": "wait",
          "ms": 2000
        },
        {
          "id": "setup-place-order",
          "action": "flow_ref",
          "ref": "order-limit-place",
          "params": {
            "symbol": "ETH",
            "side": "long",
            "usdAmount": "10",
            "limitPrice": "2000"
          }
        },
        {
          "id": "wait-order-propagate",
          "action": "wait",
          "ms": 3000
        },
        {
          "id": "pre-check-order-exists",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getOpenOrders().then(function(os){var filtered=os.filter(function(o){return o.symbol==='ETH'&&!o.isTrigger});return JSON.stringify({count:filtered.length})})",
          "assert": {
            "operator": "gt",
            "field": "count",
            "value": 0
          }
        },
        {
          "id": "run-flow",
          "action": "flow_ref",
          "ref": "order-limit-cancel",
          "params": { "symbol": "ETH" }
        },
        {
          "id": "post-verify-order-cancelled",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getOpenOrders().then(function(os){var filtered=os.filter(function(o){return o.symbol==='ETH'&&!o.isTrigger});return JSON.stringify({count:filtered.length})})",
          "assert": {
            "operator": "eq",
            "field": "count",
            "value": 0
          }
        }
      ]
    }
  }
}

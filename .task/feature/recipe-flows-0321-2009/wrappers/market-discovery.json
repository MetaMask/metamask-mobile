{
  "title": "Validate market-discovery flow with BTC",
  "validate": {
    "runtime": {
      "steps": [
        {
          "id": "run-flow",
          "action": "flow_ref",
          "ref": "market-discovery",
          "params": { "symbol": "BTC" }
        },
        {
          "id": "post-verify-price",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getMarketDataWithPrices().then(function(ms){var m=ms.find(function(x){return x.symbol==='BTC'});return JSON.stringify({price:m?m.price:'0'})})",
          "assert": {
            "operator": "not_null",
            "field": "price"
          }
        }
      ]
    }
  }
}

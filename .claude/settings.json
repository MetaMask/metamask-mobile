{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "agent-device": {
      "command": "node_modules/.bin/agent-device",
      "args": ["mcp"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "/bin/sh \"${CLAUDE_PROJECT_DIR:-.}/scripts/tooling/hook-claude-dispatch.sh\""
          }
        ]
      }
    ]
  }
}

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "if": "Read(**/.claude/skills/*/SKILL.md)",
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "[ -z \"$CI\" ] && [ \"$TOOL_USAGE_COLLECTION_OPT_IN\" != \"false\" ] && yarn tsx scripts/tooling/hook-skill-tracking.ts --agent claude || true"
          }
        ]
      }
    ]
  }
}

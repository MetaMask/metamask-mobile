{
  "title": "MYX: Full Trade Lifecycle",
  "pr": "myx-write-integration",
  "initial_conditions": { "testnet": true },
  "validate": {
    "runtime": {
      "pre_conditions": [
        "wallet.unlocked",
        "perps.myx_testnet_ready"
      ],
      "steps": [
        {
          "id": "auth",
          "description": "Verify MYX provider is authenticated",
          "action": "eval_ref",
          "ref": "myx/auth",
          "assert": { "operator": "eq", "field": "ready", "value": true }
        },
        {
          "id": "cleanup-positions",
          "description": "Close any existing positions to start clean",
          "action": "eval_ref",
          "ref": "myx/close-all-positions",
          "assert": { "operator": "not_null" }
        },
        {
          "id": "wait-clean",
          "description": "Wait for positions to clear",
          "action": "wait_for",
          "expression": "(function(){var p=Engine.context.PerpsController.providers.get('myx');return p.getPositions().then(function(r){return JSON.stringify({count:r.length})})})()",
          "timeout_ms": 60000,
          "poll_ms": 3000,
          "assert": { "operator": "eq", "field": "count", "value": 0 }
        },
        {
          "id": "step1-place-market",
          "description": "Step 1: Place market buy $150 META 2x",
          "action": "eval_ref",
          "ref": "myx/place-order",
          "assert": { "operator": "eq", "field": "success", "value": true }
        },
        {
          "id": "wait-position",
          "description": "Poll until position appears",
          "action": "wait_for",
          "expression": "(function(){var p=Engine.context.PerpsController.providers.get('myx');return p.getPositions().then(function(r){return JSON.stringify({count:r.length})})})()",
          "timeout_ms": 60000,
          "poll_ms": 3000,
          "assert": { "operator": "gt", "field": "count", "value": 0 }
        },
        {
          "id": "step2-tpsl",
          "description": "Step 2: Set TP (+10%) and SL (-5%) on position",
          "action": "eval_ref",
          "ref": "myx/update-tpsl",
          "assert": { "operator": "eq", "field": "success", "value": true }
        },
        {
          "id": "step3-add-margin",
          "description": "Step 3: Add $10 margin",
          "action": "eval_ref",
          "ref": "myx/add-margin",
          "assert": { "operator": "eq", "field": "success", "value": true }
        },
        {
          "id": "verify-position",
          "description": "Verify position still open after TP/SL + margin",
          "action": "eval_ref",
          "ref": "myx/positions",
          "assert": { "operator": "length_gt", "field": "", "value": 0 }
        },
        {
          "id": "step4-close",
          "description": "Step 4: Close position",
          "action": "eval_ref",
          "ref": "myx/close-position",
          "assert": { "operator": "eq", "field": "success", "value": true }
        },
        {
          "id": "wait-closed",
          "description": "Poll until position is gone",
          "action": "wait_for",
          "expression": "(function(){var p=Engine.context.PerpsController.providers.get('myx');return p.getPositions().then(function(r){return JSON.stringify({count:r.length})})})()",
          "timeout_ms": 60000,
          "poll_ms": 3000,
          "assert": { "operator": "eq", "field": "count", "value": 0 }
        },
        {
          "id": "log-check",
          "description": "Verify no fatal errors in Metro logs",
          "action": "log_watch",
          "window_seconds": 120,
          "must_not_appear": ["FATAL", "Unhandled promise rejection"]
        }
      ]
    }
  }
}

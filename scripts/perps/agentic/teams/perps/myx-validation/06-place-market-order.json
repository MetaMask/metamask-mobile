{
  "title": "MYX: Place Market Order",
  "pr": "myx-write-integration",
  "initial_conditions": { "testnet": true },
  "validate": {
    "runtime": {
      "pre_conditions": [
        "wallet.unlocked",
        "perps.myx_testnet_ready",
        "perps.sufficient_balance"
      ],
      "steps": [
        {
          "id": "auth",
          "description": "Verify MYX provider is authenticated",
          "action": "eval_ref",
          "ref": "myx/auth",
          "assert": { "operator": "eq", "field": "ready", "value": true }
        },
        {
          "id": "pre-snapshot",
          "description": "Snapshot position count before trade",
          "action": "eval_ref",
          "ref": "myx/pre-trade"
        },
        {
          "id": "open-position",
          "description": "Place market buy via UI",
          "action": "flow_ref",
          "ref": "trade-open-market",
          "params": { "symbol": "META", "side": "long", "usdAmount": "150" }
        },
        {
          "id": "wait-position",
          "description": "Poll until position appears (MYX chain ~10-15s)",
          "action": "wait_for",
          "expression": "(function(){var c=Engine.context.PerpsController;var p=c.providers.get('myx');if(!p)return JSON.stringify({count:0});return p.getPositions().then(function(r){return JSON.stringify({count:r.length})})})()",
          "timeout_ms": 60000,
          "poll_ms": 2000,
          "assert": { "operator": "gt", "field": "count", "value": 0 }
        },
        {
          "id": "post-snapshot",
          "description": "Verify position details",
          "action": "eval_ref",
          "ref": "myx/post-trade",
          "assert": { "operator": "gt", "field": "positionCount", "value": 0 }
        },
        {
          "id": "cleanup",
          "description": "Close the position via eval ref (faster than UI for cleanup)",
          "action": "eval_ref",
          "ref": "myx/close-position",
          "assert": { "operator": "eq", "field": "success", "value": true }
        },
        {
          "id": "wait-closed",
          "description": "Poll until position is gone",
          "action": "wait_for",
          "expression": "(function(){var c=Engine.context.PerpsController;var p=c.providers.get('myx');if(!p)return JSON.stringify({count:0});return p.getPositions().then(function(r){return JSON.stringify({count:r.length})})})()",
          "timeout_ms": 60000,
          "poll_ms": 2000,
          "assert": { "operator": "eq", "field": "count", "value": 0 }
        }
      ]
    }
  }
}

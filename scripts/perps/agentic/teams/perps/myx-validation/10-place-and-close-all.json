{
  "title": "MYX: Place Order + Close All via UI",
  "pr": "myx-write-integration",
  "initial_conditions": { "testnet": true },
  "validate": {
    "runtime": {
      "pre_conditions": [
        "wallet.unlocked",
        "perps.myx_testnet_ready",
        "perps.sufficient_balance"
      ],
      "steps": [
        {
          "id": "auth",
          "description": "Verify MYX provider is authenticated",
          "action": "eval_ref",
          "ref": "myx/auth",
          "assert": { "operator": "eq", "field": "ready", "value": true }
        },
        {
          "id": "open-position",
          "description": "Place market order via UI flow",
          "action": "flow_ref",
          "ref": "trade-open-market",
          "params": { "symbol": "META", "side": "long", "usdAmount": "150" }
        },
        {
          "id": "wait-position",
          "description": "Poll until position appears",
          "action": "wait_for",
          "expression": "(function(){var c=Engine.context.PerpsController;var p=c.providers.get('myx');if(!p)return JSON.stringify({count:0});return p.getPositions().then(function(r){return JSON.stringify({count:r.length})})})()",
          "timeout_ms": 30000,
          "poll_ms": 2000,
          "assert": { "operator": "gt", "field": "count", "value": 0 }
        },
        {
          "id": "nav-home",
          "description": "Navigate to Perps home to see positions section",
          "action": "navigate",
          "target": "PerpsMarketListView"
        },
        {
          "id": "wait-positions-section",
          "description": "Wait for positions section action button (Close All)",
          "action": "wait_for",
          "test_id": "section-header-action-button",
          "timeout_ms": 15000
        },
        {
          "id": "press-close-all",
          "description": "Press Close All action button on positions section",
          "action": "press",
          "test_id": "section-header-action-button"
        },
        {
          "id": "wait-close-all-sheet",
          "description": "Wait for Close All bottom sheet confirm button",
          "action": "wait_for",
          "test_id": "bottomsheetfooter-button-subsequent",
          "timeout_ms": 10000
        },
        {
          "id": "press-confirm-close-all",
          "description": "Press Close All confirm button in bottom sheet",
          "action": "press",
          "test_id": "bottomsheetfooter-button-subsequent"
        },
        {
          "id": "wait-closed",
          "description": "Poll until all positions gone",
          "action": "wait_for",
          "expression": "(function(){var c=Engine.context.PerpsController;var p=c.providers.get('myx');if(!p)return JSON.stringify({count:0});return p.getPositions().then(function(r){return JSON.stringify({count:r.length})})})()",
          "timeout_ms": 20000,
          "poll_ms": 1000,
          "assert": { "operator": "eq", "field": "count", "value": 0 }
        },
        {
          "id": "screenshot-after",
          "description": "Capture Perps home with no positions",
          "action": "screenshot",
          "filename": "10-close-all-after"
        }
      ]
    }
  }
}

{
  "title": "TP/SL — edit take-profit to {{newTakeProfitPrice}} for {{symbol}}",
  "inputs": {
    "symbol": {
      "type": "string",
      "description": "Market symbol with open position and existing TP/SL"
    },
    "newTakeProfitPrice": {
      "type": "string",
      "description": "New take-profit trigger price"
    }
  },
  "validate": {
    "runtime": {
      "pre_conditions": [
        "wallet.unlocked",
        {
          "name": "perps.open_position_tpsl",
          "symbol": "{{symbol}}"
        }
      ],
      "steps": [
        {
          "id": "nav-market-detail",
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "{{symbol}}",
              "name": "{{symbol}}",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          }
        },
        {
          "id": "wait-render",
          "action": "wait_for",
          "test_id": "position-card-auto-close-toggle"
        },
        {
          "id": "press-modify-tpsl",
          "action": "press",
          "test_id": "position-card-auto-close-toggle"
        },
        {
          "id": "wait-tpsl-screen",
          "action": "wait_for",
          "route": "PerpsTPSL"
        },
        {
          "id": "set-new-tp",
          "action": "set_input",
          "test_id": "perps-tpsl-tp-input",
          "value": "{{newTakeProfitPrice}}"
        },
        {
          "id": "wait-input",
          "action": "wait_for",
          "route": "PerpsTPSL"
        },
        {
          "id": "press-set-tpsl",
          "action": "press",
          "test_id": "perps-tpsl-bottomsheet"
        },
        {
          "id": "wait-submit",
          "action": "wait_for",
          "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='{{symbol}}'});return JSON.stringify({tp:p?String(p.takeProfitPrice):null})})",
          "assert": {
            "operator": "not_null",
            "field": "tp"
          }
        }
      ]
    }
  }
}

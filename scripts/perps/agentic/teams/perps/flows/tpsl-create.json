{
  "title": "TP/SL — create take-profit {{takeProfitPrice}} stop-loss {{stopLossPrice}} for {{symbol}}",
  "inputs": {
    "symbol": {
      "type": "string",
      "description": "Market symbol with open position"
    },
    "takeProfitPrice": {
      "type": "string",
      "description": "Take-profit trigger price"
    },
    "stopLossPrice": {
      "type": "string",
      "description": "Stop-loss trigger price"
    }
  },
  "validate": {
    "runtime": {
      "pre_conditions": [
        "wallet.unlocked",
        {
          "name": "perps.open_position",
          "symbol": "{{symbol}}"
        }
      ],
      "steps": [
        {
          "id": "nav-market-detail",
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "{{symbol}}",
              "name": "{{symbol}}",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          }
        },
        {
          "id": "wait-market-render",
          "action": "wait_for",
          "test_id": "position-card-auto-close-toggle"
        },
        {
          "id": "press-auto-close",
          "action": "press",
          "test_id": "position-card-auto-close-toggle"
        },
        {
          "id": "wait-tpsl-route",
          "action": "wait_for",
          "route": "PerpsTPSL"
        },
        {
          "id": "set-tp",
          "action": "set_input",
          "test_id": "perps-tpsl-tp-input",
          "value": "{{takeProfitPrice}}"
        },
        {
          "id": "wait-tp-input",
          "action": "wait_for",
          "test_id": "perps-tpsl-sl-input"
        },
        {
          "id": "set-sl",
          "action": "set_input",
          "test_id": "perps-tpsl-sl-input",
          "value": "{{stopLossPrice}}"
        },
        {
          "id": "wait-sl-input",
          "action": "wait_for",
          "test_id": "perps-tpsl-bottomsheet"
        },
        {
          "id": "assert-no-validation-error",
          "action": "log_watch",
          "window_seconds": 2,
          "must_not_appear": [
            "validation error",
            "invalid price",
            "tpsl error"
          ]
        },
        {
          "id": "assert-tpsl-screen-intact",
          "action": "eval_sync",
          "expression": "JSON.stringify({route:globalThis.__AGENTIC__.getRoute().name})",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "PerpsTPSL"
          }
        },
        {
          "id": "press-set-tpsl",
          "action": "press",
          "test_id": "perps-tpsl-bottomsheet"
        },
        {
          "id": "wait-tpsl-created",
          "action": "wait_for",
          "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='{{symbol}}'});return JSON.stringify({hasTp:!!(p&&p.takeProfitPrice),hasSl:!!(p&&p.stopLossPrice)})})",
          "assert": {
            "operator": "eq",
            "field": "hasTp",
            "value": true
          }
        }
      ]
    }
  }
}

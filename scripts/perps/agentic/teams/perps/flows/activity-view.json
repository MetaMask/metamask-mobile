{
  "title": "Activity — view recent trades and funding history",
  "validate": {
    "runtime": {
      "pre_conditions": [
        "wallet.unlocked",
        "perps.feature_enabled"
      ],
      "steps": [
        {
          "id": "nav-activity",
          "description": "Navigate to perps activity screen (perps transactions tab)",
          "action": "navigate",
          "target": "PerpsActivity",
          "params": {
            "redirectToPerpsTransactions": true
          }
        },
        {
          "id": "wait-render",
          "description": "Wait for activity screen to render",
          "action": "wait",
          "ms": 2000
        },
        {
          "id": "assert-activity-route",
          "description": "Assert on activity screen",
          "action": "eval_sync",
          "expression": "JSON.stringify({route:globalThis.__AGENTIC__.getRoute().name})",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "PerpsActivity"
          }
        },
        {
          "id": "press-tab",
          "description": "Select the requested tab (trades/orders/funding/deposits)",
          "action": "press",
          "test_id": "perps-transactions-tab-{{tab|trades}}"
        },
        {
          "id": "wait-filter",
          "description": "Wait for tab filter to apply",
          "action": "wait",
          "ms": 800
        },
        {
          "id": "assert-tab-active",
          "description": "Assert still on activity screen after tab change",
          "action": "eval_sync",
          "expression": "JSON.stringify({route:globalThis.__AGENTIC__.getRoute().name})",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "PerpsActivity"
          }
        }
      ]
    }
  }
}

{
  "title": "Position — add ${{marginAmount}} margin to {{symbol}}",
  "validate": {
    "runtime": {
      "pre_conditions": [
        "wallet.unlocked",
        {
          "name": "perps.open_position",
          "symbol": "{{symbol}}"
        }
      ],
      "steps": [
        {
          "id": "assert-position-exists",
          "description": "Assert open position exists for {{symbol}}",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getPositions().then(function(ps){var p=ps.find(function(x){return x.symbol==='{{symbol}}'});return JSON.stringify({margin:p?p.margin:null})})",
          "assert": {
            "operator": "not_null",
            "field": "margin"
          }
        },
        {
          "id": "nav-market-detail",
          "description": "Navigate to {{symbol}} market detail",
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "{{symbol}}",
              "name": "{{symbol}}",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          }
        },
        {
          "id": "wait-render",
          "description": "Wait for market detail to render",
          "action": "wait",
          "ms": 1500
        },
        {
          "id": "press-margin-chevron",
          "description": "Press margin chevron to open adjust margin action sheet",
          "action": "press",
          "test_id": "position-card-margin-chevron"
        },
        {
          "id": "wait-action-sheet",
          "description": "Wait for adjust margin action sheet",
          "action": "wait",
          "ms": 1000
        },
        {
          "id": "press-add-margin-option",
          "description": "Press Add Margin option",
          "action": "press",
          "test_id": "perps-adjust-margin-add-btn"
        },
        {
          "id": "wait-margin-screen",
          "description": "Wait for adjust margin screen",
          "action": "wait",
          "ms": 1500
        },
        {
          "id": "assert-margin-route",
          "description": "Assert on adjust margin screen",
          "action": "eval_sync",
          "expression": "JSON.stringify({route:globalThis.__AGENTIC__.getRoute().name})",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "PerpsAdjustMargin"
          }
        }
      ]
    }
  }
}

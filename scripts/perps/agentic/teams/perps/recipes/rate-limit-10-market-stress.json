{
  "title": "Perps rate-limit stress — 10 markets × 2 passes (mainnet, read-only)",
  "description": "Mobile parity with metamask-extension PR #41917. Drives rapid market switching across 10 symbols (5 HL core + 5 HIP-3) with 1500 ms dwell, an activity detour per pass, and a probe_network wrapping the run. Runs on MAINNET because (1) we never place orders so there is no risk, and (2) HL testnet returns empty candleSnapshot for HIP-3 and low-activity markets — mainnet has real candles for all 10 symbols so both price and chart gates are meaningful. Each per-market gate asserts (a) the LivePriceHeader rendered a non-placeholder live price, AND (b) the chart received >0 candles.",
  "validate": {
    "workflow": {
      "pre_conditions": ["perps.feature_enabled"],
      "entry": "wait-engine-initial",
      "nodes": {
        "wait-engine-initial": {
          "description": "Wait for __AGENTIC__ hook before checking login route. Survives cold-start and JS reload.",
          "action": "wait_for",
          "expression": "(function(){try{return JSON.stringify({ready: !!globalThis.__AGENTIC__ && typeof globalThis.__AGENTIC__.getRoute === 'function'})}catch(e){return JSON.stringify({ready:false})}})()",
          "assert": { "operator": "eq", "field": "ready", "value": true },
          "timeout_ms": 20000,
          "next": "detect-login"
        },
        "detect-login": {
          "description": "Detect whether the wallet is at Login; drives conditional unlock.",
          "action": "eval_sync",
          "expression": "(function(){try{var r=globalThis.__AGENTIC__.getRoute();return JSON.stringify({route:r.name})}catch(e){return JSON.stringify({route:'unknown'})}})()",
          "assert": { "operator": "not_null", "field": "route" },
          "next": "check-needs-unlock"
        },
        "check-needs-unlock": {
          "action": "switch",
          "cases": [
            {
              "label": "locked",
              "when": { "operator": "eq", "field": "nodes.detect-login.result.route", "value": "Login" },
              "next": "enter-password"
            }
          ],
          "default": "setup-install-probe"
        },
        "enter-password": {
          "action": "set_input",
          "test_id": "login-password-input",
          "value": "qwerasdf",
          "next": "press-login"
        },
        "press-login": {
          "action": "press",
          "test_id": "log-in-button",
          "next": "wait-post-unlock"
        },
        "wait-post-unlock": {
          "description": "Wait for route to leave Login after unlock completes.",
          "action": "wait_for",
          "expression": "(function(){var r=globalThis.__AGENTIC__.getRoute().name;return JSON.stringify({route:r,unlocked:r!=='Login'&&r!=='LoginView'})})()",
          "assert": { "operator": "eq", "field": "unlocked", "value": true },
          "timeout_ms": 15000,
          "next": "setup-install-probe"
        },
        "setup-install-probe": {
          "description": "Start network probe in metro-only mode. Mobile cannot use mitm-as-proxy for this stress test: the added latency trips the HL SDK's WS-post timeout on large responses (metaAndAssetCtxs ~1MB), causing HL to abort connections that would otherwise succeed in prod. Android also has no API to write per-Wi-Fi proxy config, so mitm teardown can strand the device (see proxy-setup-android.js). We rely on the messages.total bucket (Metro console regex for HttpRequestError / WebSocketRequestError / Too Many Requests) for parity with the extension's error-pattern acceptance — the network-level 429 count bucket is extension-only.",
          "action": "probe_network",
          "phase": "start",
          "name": "hl-traffic",
          "platform": "none",
          "preset": "hyperliquid",
          "next": "setup-bg"
        },
        "setup-bg": {
          "description": "Brief background→foreground cycle + rebind wait gives the JS context a clean settle window before the stress sequence.",
          "action": "app_background",
          "platform": "android",
          "duration_ms": 5000,
          "next": "setup-fg"
        },
        "setup-fg": {
          "action": "app_foreground",
          "platform": "android",
          "next": "setup-wait-engine"
        },
        "setup-wait-engine": {
          "description": "Wait for Engine + __AGENTIC__ hook to be ready after foreground. Survives Metro reload / JS bundle reattach mid-session.",
          "action": "wait_for",
          "expression": "(function(){try{return JSON.stringify({ready: !!globalThis.Engine && !!globalThis.__AGENTIC__ && typeof globalThis.__AGENTIC__.getRoute === 'function'})}catch(e){return JSON.stringify({ready:false})}})()",
          "assert": { "operator": "eq", "field": "ready", "value": true },
          "timeout_ms": 20000,
          "next": "setup-ensure-mainnet"
        },
        "setup-ensure-mainnet": {
          "description": "Force mainnet. Recipe is read-only (no orders placed) and HL testnet does not serve candle history for HIP-3 markets or for low-activity coins — running on mainnet gives both real price AND real candle data so the render-proof gate is meaningful for every market.",
          "action": "toggle_testnet",
          "enabled": false,
          "next": "setup-wait-mainnet"
        },
        "setup-wait-mainnet": {
          "action": "wait_for",
          "expression": "JSON.stringify({isTestnet:Engine.context.PerpsController.state.isTestnet})",
          "assert": { "operator": "eq", "field": "isTestnet", "value": false },
          "timeout_ms": 10000,
          "next": "setup-nav-perps"
        },
        "setup-nav-perps": {
          "action": "navigate",
          "target": "PerpsHomeView",
          "next": "setup-wait-markets"
        },
        "setup-wait-markets": {
          "action": "wait_for",
          "test_id": "perps-market-row-item-ETH",
          "timeout_ms": 20000,
          "next": "setup-settle"
        },
        "setup-settle": {
          "description": "Let DEX meta caches and WS snapshots hydrate before starting the stress sequence.",
          "action": "wait",
          "ms": 5000,
          "next": "run1-btc-clear"
        },

        "run1-btc-clear":  { "action": "eval_sync", "expression": "(function(){try{if(globalThis.__PERPS_PRICE_RENDERED__){delete globalThis.__PERPS_PRICE_RENDERED__['BTC'];}if(globalThis.__PERPS_CANDLES_BY_SYMBOL__){delete globalThis.__PERPS_CANDLES_BY_SYMBOL__['BTC'];}return JSON.stringify({cleared:true})}catch(e){return JSON.stringify({cleared:false})}})()", "assert": { "operator": "eq", "field": "cleared", "value": true }, "next": "run1-btc" },
        "run1-btc":        { "action": "call", "ref": "market-discovery", "params": { "symbol": "BTC" }, "next": "run1-btc-gate" },
        "run1-btc-gate":   { "action": "wait_for", "expression": "(function(){var p=(globalThis.__PERPS_PRICE_RENDERED__||{})['BTC'];var c=(globalThis.__PERPS_CANDLES_BY_SYMBOL__||{})['BTC'];return JSON.stringify({priceOk:!!p&&p.isPlaceholder===false&&p.hasPriceData===true,candlesOk:!!c&&c.candleCount>0,priceMarker:p||null,candleMarker:c||null})})()", "assert": { "all": [ { "operator": "eq", "field": "priceOk", "value": true }, { "operator": "eq", "field": "candlesOk", "value": true } ] }, "timeout_ms": 15000, "next": "run1-btc-dwell" },
        "run1-btc-dwell":  { "action": "wait", "ms": 1500, "next": "run1-eth-clear" },


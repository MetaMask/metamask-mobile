{
  "title": "Order — cancel first open limit order for {{symbol}}",
  "validate": {
    "runtime": {
      "pre_conditions": [
        "Wallet unlocked",
        "Open limit order exists for {{symbol}}"
      ],
      "steps": [
        {
          "id": "assert-order-exists",
          "description": "Assert at least one open order exists for {{symbol}}",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getOpenOrders().then(function(os){var filtered=os.filter(function(o){return o.symbol==='{{symbol}}'&&!o.isTrigger});return JSON.stringify({count:filtered.length})})",
          "assert": { "operator": "gt", "field": "count", "value": 0 }
        },
        {
          "id": "nav-market-detail",
          "description": "Navigate to {{symbol}} market detail",
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "{{symbol}}",
              "name": "{{symbol}}",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          }
        },
        {
          "id": "wait-render",
          "description": "Wait for market detail to render",
          "action": "wait",
          "ms": 1500
        },
        {
          "id": "press-orders-tab",
          "description": "Switch to Orders tab",
          "action": "press",
          "test_id": "perps-orders-tab"
        },
        {
          "id": "wait-orders-tab",
          "description": "Wait for orders tab to render",
          "action": "wait",
          "ms": 800
        },
        {
          "id": "press-cancel-first-order",
          "description": "Press cancel on first order",
          "action": "press",
          "test_id": "perps-order-cancel-btn-0"
        },
        {
          "id": "wait-cancel",
          "description": "Wait for cancellation to process",
          "action": "wait",
          "ms": 2000
        },
        {
          "id": "assert-order-removed",
          "description": "Assert order count decreased",
          "action": "eval_async",
          "expression": "Engine.context.PerpsController.getOpenOrders().then(function(os){var filtered=os.filter(function(o){return o.symbol==='{{symbol}}'&&!o.isTrigger});return JSON.stringify({count:filtered.length})})",
          "assert": { "operator": "eq", "field": "count", "value": 0 }
        },
        {
          "id": "screenshot",
          "description": "Screenshot after cancellation",
          "action": "screenshot",
          "filename": "order-limit-cancel-{{symbol}}"
        }
      ]
    }
  }
}

{
  "title": "Activity — view recent trades and funding history",
  "validate": {
    "runtime": {
      "pre_conditions": ["Wallet unlocked", "Perps feature enabled"],
      "steps": [
        {
          "id": "nav-activity",
          "description": "Navigate to perps activity screen",
          "action": "navigate",
          "target": "PerpsActivity"
        },
        {
          "id": "wait-render",
          "description": "Wait for activity screen to render",
          "action": "wait",
          "ms": 2000
        },
        {
          "id": "assert-activity-route",
          "description": "Assert on activity screen",
          "action": "eval_sync",
          "expression": "JSON.stringify({route:globalThis.__AGENTIC__.getRoute().name})",
          "assert": { "operator": "eq", "field": "route", "value": "PerpsActivity" }
        },
        {
          "id": "screenshot-top",
          "description": "Screenshot activity screen top",
          "action": "screenshot",
          "filename": "activity-view-top"
        },
        {
          "id": "scroll-down",
          "description": "Scroll down to see more activity",
          "action": "scroll",
          "test_id": "perps-activity-list",
          "offset": 400
        },
        {
          "id": "wait-scroll",
          "description": "Wait for scroll to settle",
          "action": "wait",
          "ms": 800
        },
        {
          "id": "screenshot-bottom",
          "description": "Screenshot activity screen after scroll",
          "action": "screenshot",
          "filename": "activity-view-scrolled"
        }
      ]
    }
  }
}

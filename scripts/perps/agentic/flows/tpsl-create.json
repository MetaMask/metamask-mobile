{
  "title": "TP/SL — create take-profit {{takeProfitPrice}} stop-loss {{stopLossPrice}} for {{symbol}}",
  "validate": {
    "runtime": {
      "pre_conditions": [
        "Wallet unlocked",
        "Open position exists for {{symbol}}"
      ],
      "steps": [
        {
          "id": "nav-market-detail",
          "description": "Navigate to {{symbol}} market detail",
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "{{symbol}}",
              "name": "{{symbol}}",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          }
        },
        {
          "id": "wait-market-render",
          "description": "Wait for market detail to render with position card",
          "action": "wait",
          "ms": 2000
        },
        {
          "id": "press-auto-close",
          "description": "Press auto-close toggle to open TP/SL screen",
          "action": "press",
          "test_id": "position-card-auto-close-toggle"
        },
        {
          "id": "wait-render",
          "description": "Wait for TP/SL screen to render",
          "action": "wait",
          "ms": 1500
        },
        {
          "id": "assert-tpsl-route",
          "description": "Assert on TP/SL screen",
          "action": "eval_sync",
          "expression": "JSON.stringify({route:globalThis.__AGENTIC__.getRoute().name})",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "PerpsTPSL"
          }
        },
        {
          "id": "set-tp",
          "description": "Set take-profit price to {{takeProfitPrice}}",
          "action": "set_input",
          "test_id": "perps-tpsl-tp-input",
          "value": "{{takeProfitPrice}}"
        },
        {
          "id": "wait-tp-input",
          "description": "Wait for TP input to register",
          "action": "wait",
          "ms": 500
        },
        {
          "id": "set-sl",
          "description": "Set stop-loss price to {{stopLossPrice}}",
          "action": "set_input",
          "test_id": "perps-tpsl-sl-input",
          "value": "{{stopLossPrice}}"
        },
        {
          "id": "wait-sl-input",
          "description": "Wait for SL input to register",
          "action": "wait",
          "ms": 500
        },
        {
          "id": "assert-no-validation-error",
          "description": "Assert no validation error visible",
          "action": "log_watch",
          "window_seconds": 2,
          "must_not_appear": [
            "validation error",
            "invalid price",
            "tpsl error"
          ]
        }
      ]
    }
  }
}

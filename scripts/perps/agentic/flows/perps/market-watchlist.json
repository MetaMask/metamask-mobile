{
  "title": "Market Watchlist — toggle {{symbol|BTC}} on/off watchlist",
  "validate": {
    "runtime": {
      "pre_conditions": [
        "Wallet unlocked",
        "Perps feature enabled",
        "{{symbol|BTC}} is NOT already in watchlist"
      ],
      "steps": [
        {
          "id": "nav-market-detail",
          "description": "Navigate to {{symbol|BTC}} market detail",
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "{{symbol|BTC}}",
              "name": "{{symbol|BTC}}",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          }
        },
        { "id": "wait-render", "action": "wait", "ms": 1500 },
        {
          "id": "press-favorite-add",
          "description": "Press star button to add {{symbol|BTC}} to watchlist",
          "action": "press",
          "test_id": "perps-market-header-favorite-button"
        },
        { "id": "wait-state-update", "action": "wait", "ms": 1000 },
        {
          "id": "assert-added",
          "description": "Assert {{symbol|BTC}} is now in watchlist",
          "action": "eval_sync",
          "expression": "JSON.stringify({inWatchlist:(Engine.context.PerpsController.state.watchlistMarkets.mainnet||[]).indexOf('{{symbol|BTC}}')>=0||(Engine.context.PerpsController.state.watchlistMarkets.testnet||[]).indexOf('{{symbol|BTC}}')>=0})",
          "assert": { "operator": "eq", "field": "inWatchlist", "value": true }
        },
        {
          "id": "press-favorite-remove",
          "description": "Press star button again to remove {{symbol|BTC}} from watchlist",
          "action": "press",
          "test_id": "perps-market-header-favorite-button"
        },
        { "id": "wait-state-update-2", "action": "wait", "ms": 1000 },
        {
          "id": "assert-removed",
          "description": "Assert {{symbol|BTC}} is no longer in watchlist",
          "action": "eval_sync",
          "expression": "JSON.stringify({inWatchlist:(Engine.context.PerpsController.state.watchlistMarkets.mainnet||[]).indexOf('{{symbol|BTC}}')>=0||(Engine.context.PerpsController.state.watchlistMarkets.testnet||[]).indexOf('{{symbol|BTC}}')>=0})",
          "assert": { "operator": "eq", "field": "inWatchlist", "value": false }
        }
      ]
    }
  }
}

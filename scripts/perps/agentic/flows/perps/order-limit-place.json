{
  "title": "Order — place limit {{side}} for {{symbol}} ${{usdAmount}} at {{limitPrice}}",
  "validate": {
    "runtime": {
      "pre_conditions": [
        "Wallet unlocked",
        "Perps auth active (run perps/auth recipe to verify)"
      ],
      "steps": [
        {
          "id": "nav-market-detail",
          "description": "Navigate to {{symbol}} market detail",
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "{{symbol}}",
              "name": "{{symbol}}",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          }
        },
        {
          "id": "wait-render",
          "description": "Wait for market detail to render",
          "action": "wait",
          "ms": 1500
        },
        {
          "id": "press-side",
          "description": "Press {{side}} button (navigates to RedesignedConfirmations order form)",
          "action": "press",
          "test_id": "perps-market-details-{{side}}-button"
        },
        {
          "id": "wait-order-form",
          "description": "Wait for order form to render",
          "action": "wait",
          "ms": 1500
        },
        {
          "id": "assert-order-form",
          "description": "Assert on order form screen",
          "action": "eval_sync",
          "expression": "JSON.stringify({route:globalThis.__AGENTIC__.getRoute().name})",
          "assert": {
            "operator": "eq",
            "field": "route",
            "value": "RedesignedConfirmations"
          }
        },
        {
          "id": "press-order-type",
          "description": "Open order type selector",
          "action": "press",
          "test_id": "perps-order-header-order-type-button"
        },
        {
          "id": "wait-order-type-sheet",
          "description": "Wait for order type sheet",
          "action": "wait",
          "ms": 800
        },
        {
          "id": "press-limit-type",
          "description": "Select Limit order type",
          "action": "press",
          "test_id": "perps-order-type-limit"
        },
        {
          "id": "wait-limit-form",
          "description": "Wait for limit form to update",
          "action": "wait",
          "ms": 800
        }
      ]
    }
  }
}

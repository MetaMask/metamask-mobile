{
  "title": "Order — limit {{side|long}} {{symbol|BTC}} ${{usdAmount|10}} at ${{limitPrice|60000}}",
  "validate": {
    "runtime": {
      "pre_conditions": [
        "Wallet unlocked",
        "Perps auth active"
      ],
      "steps": [
        {
          "id": "nav",
          "description": "Navigate to {{symbol|BTC}} market detail",
          "action": "navigate",
          "target": "PerpsMarketDetails",
          "params": {
            "market": {
              "symbol": "{{symbol|BTC}}",
              "name": "{{symbol|BTC}}",
              "price": "0",
              "change24h": "0",
              "change24hPercent": "0",
              "volume": "0",
              "maxLeverage": "100"
            }
          }
        },
        {
          "id": "wait-render",
          "description": "Wait for market detail to render",
          "action": "wait",
          "ms": 1500
        },
        {
          "id": "press-side",
          "description": "Press {{side|long}} button to open order form",
          "action": "press",
          "test_id": "perps-market-details-{{side|long}}-button"
        },
        {
          "id": "wait-form",
          "description": "Wait for order form to render",
          "action": "wait",
          "ms": 1500
        },
        {
          "id": "press-order-type",
          "description": "Open order type selector",
          "action": "press",
          "test_id": "perps-order-header-order-type-button"
        },
        {
          "id": "wait-type-sheet",
          "description": "Wait for order type sheet",
          "action": "wait",
          "ms": 800
        },
        {
          "id": "press-limit",
          "description": "Select Limit order type",
          "action": "press",
          "test_id": "perps-order-type-limit"
        },
        {
          "id": "wait-limit-form",
          "description": "Wait for limit form to update",
          "action": "wait",
          "ms": 800
        },
        {
          "id": "press-limit-price-row",
          "description": "Open limit price bottom sheet",
          "action": "press",
          "test_id": "perps-order-view-limit-price-row"
        },
        {
          "id": "wait-price-sheet",
          "description": "Wait for limit price sheet to open",
          "action": "wait",
          "ms": 800
        },
        {
          "id": "type-limit-price",
          "description": "Type ${{limitPrice|60000}} using keypad",
          "action": "type_keypad",
          "value": "{{limitPrice|60000}}"
        },
        {
          "id": "press-set",
          "description": "Confirm limit price",
          "action": "press",
          "test_id": "perps-limit-price-confirm-button"
        },
        {
          "id": "wait-price-set",
          "description": "Wait for price to be applied",
          "action": "wait",
          "ms": 500
        },
        {
          "id": "press-amount",
          "description": "Tap amount display to open keypad",
          "action": "press",
          "test_id": "perps-amount-display-touchable"
        },
        {
          "id": "wait-keypad",
          "description": "Wait for keypad to appear",
          "action": "wait",
          "ms": 500
        },
        {
          "id": "type-amount",
          "description": "Type ${{usdAmount|10}} using keypad",
          "action": "type_keypad",
          "value": "{{usdAmount|10}}"
        },
        {
          "id": "press-done",
          "description": "Press Done to close keypad",
          "action": "press",
          "test_id": "perps-order-view-keypad-done"
        },
        {
          "id": "wait-summary",
          "description": "Wait for order summary to update",
          "action": "wait",
          "ms": 800
        },
        {
          "id": "place-order",
          "description": "Press Place Order button",
          "action": "press",
          "test_id": "perps-order-view-place-order-button"
        },
        {
          "id": "wait-confirm",
          "description": "Wait for order confirmation",
          "action": "wait",
          "ms": 2000
        }
      ]
    }
  }
}

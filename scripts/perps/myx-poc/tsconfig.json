{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@myx-trade/sdk": ["../../../node_modules/@myx-trade/sdk"],
      "ethers": ["../../../node_modules/ethers"],
      "viem": ["../../../node_modules/viem"],
      "viem/*": ["../../../node_modules/viem/*"]
    }
  },
  "include": ["*.ts"]
}

{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "/bin/sh scripts/tooling/hook-cursor-dispatch.sh",
        "timeout": 5
      }
    ],
    "beforeSubmitPrompt": [
      {
        "matcher": "UserPromptSubmit",
        "command": "/bin/sh scripts/tooling/hook-cursor-prompt-dispatch.sh",
        "timeout": 2
      }
    ]
  }
}

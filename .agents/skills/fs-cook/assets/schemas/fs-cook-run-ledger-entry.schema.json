{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fs-cook-run-ledger-entry.schema.json",
  "type": "object",
  "required": [
    "run_id",
    "version_id_under_test",
    "task_artifact_dir",
    "learning_artifact_path",
    "recipe_path",
    "recipe_cook_path",
    "validator_manifest_path",
    "scenario_lane",
    "result_summary",
    "quality_semantic",
    "quality",
    "pass_rate",
    "inference_cost_usd",
    "source_run_id"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "version_id_under_test": { "type": "string" },
    "task_artifact_dir": { "type": "string" },
    "learning_artifact_path": { "type": "string" },
    "recipe_path": { "type": "string" },
    "recipe_cook_path": { "type": ["string", "null"] },
    "validator_manifest_path": { "type": "string" },
    "scenario_lane": { "type": "string" },
    "result_summary": { "type": "string" },
    "quality_semantic": { "type": "string", "enum": ["good", "ok", "bad"] },
    "quality": { "type": "number" },
    "pass_rate": { "type": ["number", "null"] },
    "inference_cost_usd": { "type": ["number", "null"] },
    "source_run_id": { "type": "string" }
  }
}

        testID="onboarding-success-manage-default-settings-button"
      >
        <Text
          accessibilityRole="text"
          style={
            [
              {
                "color": "#4459ff",
                "fontFamily": "Geist-Medium",
                "fontSize": 16,
                "fontWeight": 400,
                "letterSpacing": 0,
                "lineHeight": 24,
              },
              undefined,
            ]
          }
        >
          Manage default settings
        </Text>
      </TouchableOpacity>
    </View>
  </View>
</RNCSafeAreaView>
`;

<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
	<domain-config cleartextTrafficPermitted="true">
		<domain includeSubdomains="true">sslip.io</domain>
		<domain includeSubdomains="false">localhost</domain>
		<domain includeSubdomains="false">10.0.2.2</domain>
		<domain includeSubdomains="false">10.0.3.2</domain>
	</domain-config>
	<base-config cleartextTrafficPermitted="true">
		<trust-anchors>
			<certificates src="system" />
			<certificates src="user" />
			<!-- Bundled E2E proxy CA (Decision DA/A1): trusted without any
			     runtime adb install. Must stay byte-identical to
			     tests/framework/utils/e2e-proxy-ca/proxy-ca.pem - guarded by
			     a unit test in E2EProxyCa.test.ts. -->
			<certificates src="@raw/e2e_proxy_ca" />
		</trust-anchors>
	</base-config>
</network-security-config>

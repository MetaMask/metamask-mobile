def common_target_logic
  podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

  use_expo_modules!
	# config = use_native_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  # Pods for MetaMask
  pod 'ReactNativePayments', :path => '../node_modules/@metamask/react-native-payments/lib/ios/'

  # Pods for Push Notifications
  pod 'FirebaseCore', :modular_headers => true
  pod 'GoogleUtilities/NSData+zlib', :modular_headers => true

   # Comment the next line if you don't want to use dynamic frameworks
  # use_frameworks!
	pod 'Permission-BluetoothPeripheral', :path => '../node_modules/react-native-permissions/ios/BluetoothPeripheral'
  pod 'GzipSwift'

  # Pod for fixing react-native-quick-crypto issue: https://github.com/margelo/react-native-quick-crypto/issues/244
  pod 'OpenSSL-Universal', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
    :hermes_enabled => true
  )
end

target 'MetaMask' do
  common_target_logic
end

target 'MetaMask-QA' do
  common_target_logic
end

target 'MetaMask-Flask' do
	common_target_logic
end

if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
  config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
else
  config_command = [
    'node',
    '--no-warnings',
    '--eval',
    'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
    'react-native-config',
    '--json',
    '--platform',
    'ios'
  ]
end

config = use_native_modules!(config_command)

post_install do |installer|
  react_native_post_install(
    installer,
    config[:reactNativePath],
    :mac_catalyst_enabled => false,
    :ccache_enabled => podfile_properties['apple.ccacheEnabled'] == 'true',
  )

  # Fix TangemSdk ambiguous ActivityIndicatorView init for newer Swift compilers
  tangem_file = installer.sandbox.root + "TangemSdk/TangemSdk/TangemSdk/UI/Views/Common/RoundedButtonStyle.swift"
  if File.exist?(tangem_file)
    begin
      system "chmod +w #{tangem_file}"
      contents = File.read(tangem_file)
      modified_contents = contents.gsub(
        'ActivityIndicatorView()',
        'ActivityIndicatorView(color: Color.white)'
      )
      File.write(tangem_file, modified_contents)
      system "chmod -w #{tangem_file}"
    rescue => e
      Pod::UI.warn "Failed to patch TangemSdk RoundedButtonStyle.swift: #{e.message}"
    end
  end

  # Add TangemSdk_secp256k1 C module to the CocoaPods-generated modulemap so
  # the Swift compiler can resolve `import TangemSdk_secp256k1` inside TangemSdk.
  tangem_modulemap = installer.sandbox.root + "Headers/Public/TangemSdk/TangemSdk.modulemap"
  tangem_secp_header_dir = installer.sandbox.root + "TangemSdk/TangemSdk/TangemSdk/Crypto/secp256k1/src/include"
  if File.exist?(tangem_modulemap) && Dir.exist?(tangem_secp_header_dir)
    begin
      system "chmod +w #{tangem_modulemap}"
      contents = File.read(tangem_modulemap)
      unless contents.include?('TangemSdk_secp256k1')
        secp_module = <<~MODULEMAP

          module TangemSdk_secp256k1 [system] {
            header "#{tangem_secp_header_dir}/tangem_secp256k1.h"
            header "#{tangem_secp_header_dir}/secp256k1_ecdh.h"
            header "#{tangem_secp_header_dir}/secp256k1_recovery.h"
            header "#{tangem_secp_header_dir}/secp256k1_preallocated.h"
            export *
          }
        MODULEMAP
        File.write(tangem_modulemap, contents + secp_module)
      end
    rescue => e
      Pod::UI.warn "Failed to patch TangemSdk modulemap: #{e.message}"
    end
  end

  # Fix secp256k1 duplicate symbol collision: NativeUtils and TangemSdk both
  # compile their own secp256k1.c with identical public API symbols. At runtime
  # the linker silently resolves duplicates, but version mismatches between the
  # two implementations corrupt quick-crypto's symmetric key operations.
  #
  # Solution: enable ECDH + recovery modules in NativeUtils' secp256k1 (which
  # already ships the source but doesn't compile them), then remove TangemSdk's
  # duplicate secp256k1.c so it links against NativeUtils' single implementation.
  installer.pods_project.targets.each do |target|
    if target.name == 'NativeUtils'
      target.build_configurations.each do |config|
        defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || '$(inherited)'
        unless defs.include?('ENABLE_MODULE_ECDH')
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = "#{defs} ENABLE_MODULE_ECDH=1 ENABLE_MODULE_RECOVERY=1"
        end
      end
    end
    if target.name == 'TangemSdk'
      target.source_build_phase.files.each do |build_file|
        if build_file.file_ref&.path&.end_with?('secp256k1.c')
          target.source_build_phase.remove_build_file(build_file)
          Pod::UI.message "Removed duplicate secp256k1.c from TangemSdk sources"
        end
      end
    end
  end

  # Point SWIFT_INCLUDE_PATHS at the TangemSdk secp256k1 modulemap dir for all
  # targets that depend on TangemSdk.
  installer.pods_project.targets.each do |target|
    if ['TangemSdk', 'tangem-sdk-react-native'].include?(target.name)
      target.build_configurations.each do |config|
        secp_path = "#{installer.sandbox.root}/TangemSdk/TangemSdk/TangemSdk/Crypto/secp256k1/src/include"
        existing = config.build_settings['SWIFT_INCLUDE_PATHS'] || '$(inherited)'
        unless existing.include?(secp_path)
          config.build_settings['SWIFT_INCLUDE_PATHS'] = "#{existing} \"#{secp_path}\""
        end
        existing_hdr = config.build_settings['HEADER_SEARCH_PATHS'] || '$(inherited)'
        unless existing_hdr.include?(secp_path)
          config.build_settings['HEADER_SEARCH_PATHS'] = "#{existing_hdr} \"#{secp_path}\""
        end
      end
    end
  end

  # Modify RCT-Folly Portability.h to disable coroutines
  Dir.glob(installer.sandbox.root + "RCT-Folly/folly/Portability.h") do |file|
    begin
      # First try to make the file writable
      system "chmod +w #{file}"

      contents = File.read(file)
      modified_contents = contents.gsub(/#define FOLLY_HAS_COROUTINES 1/, '#define FOLLY_HAS_COROUTINES 0')

      # Try writing with elevated privileges if needed
      if !File.writable?(file)
        system "sudo chmod +w #{file}"
      end

      File.write(file, modified_contents)

      # Optionally restore original permissions
      system "chmod -w #{file}"
    rescue => e
      Pod::UI.warn "Failed to modify Portability.h: #{e.message}"
    end
  end

  # This is necessary for Xcode 14, because it signs resource bundles by default
  # when building for devices.
  installer.target_installation_results.pod_target_installation_results
    .each do |pod_name, target_installation_result|
    target_installation_result.resource_bundle_targets.each do |resource_bundle_target|
      resource_bundle_target.build_configurations.each do |config|
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      end
    end
  end
end

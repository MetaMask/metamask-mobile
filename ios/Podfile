def common_target_logic
  podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

  use_expo_modules!
	# config = use_native_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  # Pods for MetaMask
  pod 'ReactNativePayments', :path => '../node_modules/@metamask/react-native-payments/lib/ios/'

  # Pods for Push Notifications
  pod 'FirebaseCore', :modular_headers => true
  pod 'GoogleUtilities/NSData+zlib', :modular_headers => true

   # Comment the next line if you don't want to use dynamic frameworks
  # use_frameworks!
	pod 'Permission-BluetoothPeripheral', :path => '../node_modules/react-native-permissions/ios/BluetoothPeripheral'
  pod 'GzipSwift'

  # Pod for fixing react-native-quick-crypto issue: https://github.com/margelo/react-native-quick-crypto/issues/244
  pod 'OpenSSL-Universal', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
    :hermes_enabled => true
  )

  # NitroFetch (Swift) requires React-RCTNetwork to export module maps
  pod 'React-RCTNetwork', :path => "#{config[:reactNativePath]}/Libraries/Network", :modular_headers => true
end

target 'MetaMask' do
  common_target_logic
end

target 'MetaMask-Flask' do
	common_target_logic
end

if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
  config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
else
  config_command = [
    'node',
    '--no-warnings',
    '--eval',
    'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
    'react-native-config',
    '--json',
    '--platform',
    'ios'
  ]
end

config = use_native_modules!(config_command)

# E2E-only patch that forces SocketRocket (React Native's WebSocket transport)
# to route ws:// and wss:// connections through the local E2E HTTP proxy.
#
# Why a source patch: SocketRocket reads proxy settings from the device's
# system proxy configuration, which the iOS Simulator inherits from the host
# Mac — it cannot be set per-app. The patch injects an early-return hook into
# SRProxyConnect's `_configureProxy` that reads the `e2eIosProxyPort` launch
# argument (same contract as E2ENativeAppProxy.swift) and, when present,
# targets 127.0.0.1:<port> instead.
#
# Patched invariants this relies on (re-verify on SocketRocket version bumps):
#   - `SRProxyConnect.m` lives at Internal/Proxy/ and contains a
#     `- (void)_configureProxy` method opening with `SRDebugLog(@"configureProxy");`
#   - `_httpProxyHost` / `_httpProxyPort` ivars carry the proxy target and
#     `_openConnection` starts the proxied connect
#   - localhost / 127.0.0.1 / ::1 / *.local destinations bypass the proxy so
#     the harness's own local servers stay directly reachable
#
# Applied only when METAMASK_ENVIRONMENT=e2e. Any failure to apply raises so
# `pod install` (and therefore CI) fails loudly rather than silently producing
# an E2E binary whose native WebSocket traffic bypasses the proxy.
def apply_e2e_socketrocket_proxy_patch(installer)
  file = File.join(
    installer.sandbox.root.to_s,
    'SocketRocket/SocketRocket/Internal/Proxy/SRProxyConnect.m'
  )
  marker = 'E2E_IOS_NATIVE_APP_PROXY_WEBSOCKET_ENABLED'

  unless File.exist?(file)
    raise "SocketRocket E2E native proxy patch: #{file} not found (did the SocketRocket pod layout change?)"
  end

  contents = File.read(file)
  if contents.include?(marker)
    Pod::UI.puts 'SocketRocket E2E native proxy patch already applied'.yellow
    return
  end

  helper = <<~'OBJC'
    static NSString *SRE2ELaunchArgumentValue(NSString *name)
    {
        NSArray<NSString *> *arguments = NSProcessInfo.processInfo.arguments;

        for (NSUInteger index = 0; index < arguments.count; index++) {
            NSString *argument = arguments[index];
            if ([argument isEqualToString:name] || [argument isEqualToString:[@"-" stringByAppendingString:name]]) {
                NSUInteger nextIndex = index + 1;
                return nextIndex < arguments.count ? arguments[nextIndex] : nil;
            }

            NSArray<NSString *> *prefixes = @[
                [name stringByAppendingString:@"="],
                [[@"-" stringByAppendingString:name] stringByAppendingString:@"="]
            ];
            for (NSString *prefix in prefixes) {
                if ([argument hasPrefix:prefix]) {
                    return [argument substringFromIndex:prefix.length];
                }
            }
        }

        return NSProcessInfo.processInfo.environment[name];
    }

    static BOOL SRE2EIsLocalHost(NSString *host)
    {
        NSString *lowercaseHost = host.lowercaseString ?: @"";
        return [lowercaseHost isEqualToString:@"localhost"] ||
            [lowercaseHost isEqualToString:@"127.0.0.1"] ||
            [lowercaseHost isEqualToString:@"::1"] ||
            [lowercaseHost isEqualToString:@"10.0.2.2"] ||
            [lowercaseHost hasSuffix:@".local"];
    }

    - (BOOL)_configureE2EProxyIfNeeded
    {
        NSString *proxyPortString = SRE2ELaunchArgumentValue(@"e2eIosProxyPort");
        NSInteger proxyPort = proxyPortString.integerValue;

        if (proxyPort <= 0 || proxyPort > 65535 || SRE2EIsLocalHost(_url.host)) {
            return NO;
        }

        _httpProxyHost = @"127.0.0.1";
        _httpProxyPort = (uint32_t)proxyPort;

        NSLog(@"[E2E_IOS_NATIVE_APP_PROXY_WEBSOCKET_ENABLED] SocketRocket %@://%@ will use HTTP proxy %@:%u",
              _connectionRequiresSSL ? @"wss" : @"ws",
              _url.host ?: @"unknown",
              _httpProxyHost,
              _httpProxyPort);

        [self _openConnection];
        return YES;
    }
  OBJC

  needle = <<~'OBJC'
    // get proxy setting from device setting
    - (void)_configureProxy
    {
        SRDebugLog(@"configureProxy");
  OBJC

  replacement = <<~'OBJC'
    // get proxy setting from device setting
    - (void)_configureProxy
    {
        SRDebugLog(@"configureProxy");
        if ([self _configureE2EProxyIfNeeded]) {
            return;
        }
  OBJC

  modified = contents.sub(needle, "#{helper}\n#{replacement}")
  if modified == contents
    raise 'SocketRocket E2E native proxy patch: expected _configureProxy block not found (SocketRocket source changed — update the patch invariants above)'
  end

  system "chmod +w #{file}"
  File.write(file, modified)
  unless File.read(file).include?(marker)
    raise 'SocketRocket E2E native proxy patch: marker missing after write — patch did not stick'
  end
  Pod::UI.puts 'Applied SocketRocket E2E native proxy patch'.green
end

post_install do |installer|
  react_native_post_install(
    installer,
    config[:reactNativePath],
    :mac_catalyst_enabled => false,
    :ccache_enabled => podfile_properties['apple.ccacheEnabled'] == 'true',
  )

  # Modify RCT-Folly Portability.h to disable coroutines
  Dir.glob(installer.sandbox.root + "RCT-Folly/folly/Portability.h") do |file|
    begin
      # First try to make the file writable
      system "chmod +w #{file}"

      contents = File.read(file)
      modified_contents = contents.gsub(/#define FOLLY_HAS_COROUTINES 1/, '#define FOLLY_HAS_COROUTINES 0')

      # Try writing with elevated privileges if needed
      if !File.writable?(file)
        system "sudo chmod +w #{file}"
      end

      File.write(file, modified_contents)

      # Optionally restore original permissions
      system "chmod -w #{file}"
    rescue => e
      Pod::UI.warn "Failed to modify Portability.h: #{e.message}"
    end
  end

  # Fix fmt compilation error with Xcode 26 / Clang 21 consteval strictness
  # Directly disable FMT_USE_CONSTEVAL rather than patching the detection logic.
  # Uses regex to handle indented preprocessor directives (e.g. "#  define").
  Dir.glob(installer.sandbox.root + "fmt/include/fmt/base.h") do |file|
    begin
      system "chmod +w #{file}"
      contents = File.read(file)
      modified = contents.gsub(/#\s*define FMT_USE_CONSTEVAL 1/, '#define FMT_USE_CONSTEVAL 0')
      if !File.writable?(file)
        system "sudo chmod +w #{file}"
      end
      File.write(file, modified)
      system "chmod -w #{file}"
    rescue => e
      Pod::UI.warn "Failed to modify fmt base.h: #{e.message}"
    end
  end

  if ENV['METAMASK_ENVIRONMENT'] == 'e2e'
    apply_e2e_socketrocket_proxy_patch(installer)
  else
    Pod::UI.puts 'Skipping SocketRocket E2E native proxy patch outside METAMASK_ENVIRONMENT=e2e'.yellow
  end

  # This is necessary for Xcode 14, because it signs resource bundles by default
  # when building for devices.
  installer.target_installation_results.pod_target_installation_results
    .each do |pod_name, target_installation_result|
    target_installation_result.resource_bundle_targets.each do |resource_bundle_target|
      resource_bundle_target.build_configurations.each do |config|
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      end
    end
  end
end

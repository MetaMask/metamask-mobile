+{"version":3,"file":"tokens-api-v3.mjs","sourceRoot":"","sources":["../src/tokens-api-v3.ts"],"names":[],"mappings":"AAAA,OAAO,EAAE,mBAAmB,EAAE,WAAW,EAAE,mCAAmC;AAK9E,MAAM,CAAC,MAAM,sBAAsB,GAAG,sCAAsC,CAAC;AAE7E;;;GAGG;AACH,MAAM,CAAC,MAAM,cAAc,GAAG,EAAE,CAAC;AAEjC;;;;GAIG;AACH,MAAM,CAAC,MAAM,eAAe,GAAG,CAAC,CAAC;AAajC,yEAAyE;AACzE,uBAAuB;AACvB,MAAM,QAAQ,GAAG,IAAI,GAAG,EAAmC,CAAC;AAE5D;;;;;GAKG;AACH,KAAK,UAAU,eAAe,CAAC,QAAkB;IAC/C,MAAM,GAAG,GAAG,QAAQ,CAAC,IAAI,CAAC,GAAG,CAAC,CAAC;IAE/B,MAAM,QAAQ,GAAG,QAAQ,CAAC,GAAG,CAAC,GAAG,CAAC,CAAC;IACnC,IAAI,QAAQ,EAAE,CAAC;QACb,OAAO,QAAQ,CAAC;IAClB,CAAC;IAED,MAAM,MAAM,GAAG,IAAI,eAAe,CAAC;QACjC,QAAQ,EAAE,QAAQ,CAAC,IAAI,CAAC,GAAG,CAAC;QAC5B,kBAAkB,EAAE,MAAM;QAC1B,cAAc,EAAE,MAAM;QACtB,kBAAkB,EAAE,MAAM;QAC1B,cAAc,EAAE,MAAM;KACvB,CAAC,CAAC;IAEH,MAAM,OAAO,GAAG,CAAC,KAAK,IAA6B,EAAE;QACnD,IAAI,CAAC;YACH,MAAM,IAAI,GAAG,CAAC,MAAM,WAAW,CAC7B,GAAG,sBAAsB,WAAW,MAAM,EAAE,CAC7C,CAAmB,CAAC;YACrB,OAAO,KAAK,CAAC,OAAO,CAAC,IAAI,CAAC,CAAC,CAAC,CAAC,IAAI,CAAC,CAAC,CAAC,EAAE,CAAC;QACzC,CAAC;gBAAS,CAAC;YACT,QAAQ,CAAC,MAAM,CAAC,GAAG,CAAC,CAAC;QACvB,CAAC;IACH,CAAC,CAAC,EAAE,CAAC;IAEL,QAAQ,CAAC,GAAG,CAAC,GAAG,EAAE,OAAO,CAAC,CAAC;IAC3B,OAAO,OAAO,CAAC;AACjB,CAAC;AAED;;;;;;GAMG;AACH,KAAK,UAAU,gBAAgB,CAAC,QAAkB;IAChD,MAAM,OAAO,GAAe,EAAE,CAAC;IAC/B,KAAK,IAAI,CAAC,GAAG,CAAC,EAAE,CAAC,GAAG,QAAQ,CAAC,MAAM,EAAE,CAAC,IAAI,cAAc,EAAE,CAAC;QACzD,OAAO,CAAC,IAAI,CAAC,QAAQ,CAAC,KAAK,CAAC,CAAC,EAAE,CAAC,GAAG,cAAc,CAAC,CAAC,CAAC;IACtD,CAAC;IACD,MAAM,OAAO,GAAG,MAAM,OAAO,CAAC,GAAG,CAAC,OAAO,CAAC,GAAG,CAAC,eAAe,CAAC,CAAC,CAAC;IAChE,OAAO,OAAO,CAAC,IAAI,EAAE,CAAC;AACxB,CAAC;AAED;;;;;;GAMG;AACH,MAAM,UAAU,gBAAgB,CAAC,OAAY,EAAE,YAAoB;IACjE,MAAM,cAAc,GAAG,mBAAmB,CAAC,OAAO,CAAC,CAAC;IACpD,OAAO,UAAU,cAAc,UAAU,YAAY,CAAC,WAAW,EAAE,EAAE,CAAC;AACxE,CAAC;AAED;;;;;;;;;;GAUG;AACH,MAAM,CAAC,KAAK,UAAU,8BAA8B,CAClD,OAAY,EACZ,cAAwB;IAExB,IAAI,cAAc,CAAC,MAAM,KAAK,CAAC,EAAE,CAAC;QAChC,OAAO,IAAI,GAAG,EAAE,CAAC;IACnB,CAAC;IAED,MAAM,QAAQ,GAAG,cAAc,CAAC,GAAG,CAAC,CAAC,OAAO,EAAE,EAAE,CAC9C,gBAAgB,CAAC,OAAO,EAAE,OAAO,CAAC,CACnC,CAAC;IAEF,MAAM,MAAM,GAAG,MAAM,gBAAgB,CAAC,QAAQ,CAAC,CAAC;IAEhD,MAAM,MAAM,GAAG,IAAI,GAAG,EAAwB,CAAC;IAC/C,KAAK,MAAM,KAAK,IAAI,MAAM,EAAE,CAAC;QAC3B,IAAI,KAAK,CAAC,WAAW,IAAI,eAAe,EAAE,CAAC;YACzC,iFAAiF;YACjF,MAAM,OAAO,GAAG,KAAK,CAAC,OAAO,CAAC,KAAK,CAAC,SAAS,CAAC,CAAC,CAAC,CAAC,EAAE,WAAW,EAAE,CAAC;YACjE,IAAI,OAAO,EAAE,CAAC;gBACZ,MAAM,CAAC,GAAG,CAAC,OAAO,EAAE,KAAK,CAAC,CAAC;YAC7B,CAAC;QACH,CAAC;IACH,CAAC;IAED,OAAO,MAAM,CAAC;AAChB,CAAC","sourcesContent":["import { convertHexToDecimal, handleFetch } from '@metamask/controller-utils';\nimport type { Hex } from '@metamask/utils';\n\nimport type { TokenRwaData } from './token-service';\n\nexport const TOKENS_API_V3_BASE_URL = 'https://tokens.api.cx.metamask.io/v3';\n\n/**\n * Maximum number of asset IDs per API request. Requests with more IDs are\n * split into parallel batches of this size.\n */\nexport const MAX_BATCH_SIZE = 25;\n\n/**\n * The minimum number of occurrences (aggregator listings) a token must have to\n * be considered verified. Tokens below this threshold are treated as potential\n * spam and excluded from detection results.\n */\nexport const MIN_OCCURRENCES = 3;\n\nexport type TokenV3Asset = {\n  assetId: string;\n  decimals: number;\n  iconUrl: string;\n  name: string;\n  symbol: string;\n  occurrences: number;\n  aggregators?: string[];\n  rwaData?: TokenRwaData;\n};\n\n// In-flight deduplication so parallel callers for the same batch share a\n// single HTTP request.\nconst inFlight = new Map<string, Promise<TokenV3Asset[]>>();\n\n/**\n * Fetch a single batch of token metadata from the v3 API.\n *\n * @param assetIds - CAIP-19 asset IDs for this batch (max {@link MAX_BATCH_SIZE}).\n * @returns Resolved token assets returned by the API.\n */\nasync function fetchTokenBatch(assetIds: string[]): Promise<TokenV3Asset[]> {\n  const key = assetIds.join(',');\n\n  const existing = inFlight.get(key);\n  if (existing) {\n    return existing;\n  }\n\n  const params = new URLSearchParams({\n    assetIds: assetIds.join(','),\n    includeOccurrences: 'true',\n    includeIconUrl: 'true',\n    includeAggregators: 'true',\n    includeRwaData: 'true',\n  });\n\n  const promise = (async (): Promise<TokenV3Asset[]> => {\n    try {\n      const data = (await handleFetch(\n        `${TOKENS_API_V3_BASE_URL}/assets?${params}`,\n      )) as TokenV3Asset[];\n      return Array.isArray(data) ? data : [];\n    } finally {\n      inFlight.delete(key);\n    }\n  })();\n\n  inFlight.set(key, promise);\n  return promise;\n}\n\n/**\n * Fetch token metadata from the v3 tokens API for the given asset IDs,\n * splitting large inputs into parallel batches of at most {@link MAX_BATCH_SIZE}.\n *\n * @param assetIds - CAIP-19 asset IDs to fetch.\n * @returns All resolved token assets across all batches.\n */\nasync function fetchTokenAssets(assetIds: string[]): Promise<TokenV3Asset[]> {\n  const batches: string[][] = [];\n  for (let i = 0; i < assetIds.length; i += MAX_BATCH_SIZE) {\n    batches.push(assetIds.slice(i, i + MAX_BATCH_SIZE));\n  }\n  const results = await Promise.all(batches.map(fetchTokenBatch));\n  return results.flat();\n}\n\n/**\n * Build a CAIP-19 ERC-20 asset ID from a chain ID and a token address.\n *\n * @param chainId - Hex chain ID (e.g. `0x1`).\n * @param tokenAddress - ERC-20 contract address (any casing).\n * @returns CAIP-19 asset ID string, e.g. `eip155:1/erc20:0xabc...`.\n */\nexport function buildCaipAssetId(chainId: Hex, tokenAddress: string): string {\n  const decimalChainId = convertHexToDecimal(chainId);\n  return `eip155:${decimalChainId}/erc20:${tokenAddress.toLowerCase()}`;\n}\n\n/**\n * Fetch token metadata for the given ERC-20 addresses on a specific chain,\n * filtering out tokens that do not meet the minimum occurrences threshold\n * (spam filter).\n *\n * Results are keyed by lowercase token address for easy lookup.\n *\n * @param chainId - Hex chain ID.\n * @param tokenAddresses - ERC-20 token addresses to look up.\n * @returns Map from lowercase token address to verified token asset data.\n */\nexport async function fetchVerifiedTokensByAddresses(\n  chainId: Hex,\n  tokenAddresses: string[],\n): Promise<Map<string, TokenV3Asset>> {\n  if (tokenAddresses.length === 0) {\n    return new Map();\n  }\n\n  const assetIds = tokenAddresses.map((address) =>\n    buildCaipAssetId(chainId, address),\n  );\n\n  const assets = await fetchTokenAssets(assetIds);\n\n  const result = new Map<string, TokenV3Asset>();\n  for (const asset of assets) {\n    if (asset.occurrences >= MIN_OCCURRENCES) {\n      // Extract the address part from the CAIP-19 ID: \"eip155:1/erc20:0xabc\" → \"0xabc\"\n      const address = asset.assetId.split('/erc20:')[1]?.toLowerCase();\n      if (address) {\n        result.set(address, asset);\n      }\n    }\n  }\n\n  return result;\n}\n"]}
